                        "rules_fired": "={{$json.rules_fired}}",
                        "clean_reply": "={{$json.clean_reply}}",
                        "event_id": "={{$json.event_id}}",
                        "sent_status": "={{$json.sent_status}}"
                    },
                    "matchingColumns": [
                        "ticket_id"
                    ],
